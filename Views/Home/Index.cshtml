@model ObligatorioApiario.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />

<style>
    .home-dashboard-wrapper {
        padding: 20px;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
    }
    
    .stats-row {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .stat-card {
        flex: 1;
        background-color: var(--topbar-bg, #ffffff);
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        display: flex;
        align-items: center;
        gap: 20px;
        border-left: 4px solid #d4a373;
        transition: transform 0.2s ease;
        border: 1px solid rgba(0,0,0,0.05);
        border-left-width: 4px;
    }

    .stat-card:hover {
        transform: translateY(-5px);
    }
    
    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        background: #fff4e6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: #d4a373;
    }
    
    .stat-details h3 {
        margin: 0;
        font-size: 0.9rem;
        color: #7a6e62;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .stat-details p {
        margin: 5px 0 0 0;
        font-size: 1.8rem;
        font-weight: 700;
        color: #2d261e;
    }
    
    .middle-row {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .chart-container, .tasks-container, .map-container {
        background-color: var(--topbar-bg, #ffffff);
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(0,0,0,0.05);
    }
    
    .chart-container {
        flex: 2;
        min-width: 0;
    }
    
    .tasks-container {
        flex: 1;
        min-width: 0;
    }

    .map-container {
        width: 100%;
        margin-top: 20px;
    }
    
    .section-title {
        font-size: 1.2rem;
        color: #2d261e;
        margin-top: 0;
        margin-bottom: 20px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .task-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px 0;
        border-bottom: 1px solid #f0ebe1;
    }
    
    .task-item:last-child {
        border-bottom: none;
    }
    
    .task-date {
        background: #fdfbf7;
        border: 1px solid #e8e3dc;
        padding: 8px;
        border-radius: 8px;
        text-align: center;
        min-width: 60px;
    }
    
    .task-date .day {
        display: block;
        font-size: 1.2rem;
        font-weight: 700;
        color: #d4a373;
    }
    
    .task-date .month {
        display: block;
        font-size: 0.75rem;
        color: #7a6e62;
        text-transform: uppercase;
    }
    
    .task-info h4 {
        margin: 0 0 4px 0;
        font-size: 1rem;
        color: #2d261e;
    }
    
    .task-info p {
        margin: 0;
        font-size: 0.85rem;
        color: #7a6e62;
    }
    
    #map {
        height: 400px;
        width: 100%;
        border-radius: 8px;
        z-index: 1;
    }

    /* Serialize data for JS */
    #chartData, #mapData {
        display: none;
    }
</style>

<div class="home-dashboard-wrapper">
    
    <!-- Top Row: Stats -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon"><i class="fa-solid fa-location-dot"></i></div>
            <div class="stat-details">
                <h3>Total Apiarios</h3>
                <p>@Model.TotalApiarios</p>
            </div>
        </div>
        <div class="stat-card" style="border-left-color: #5c4e40;">
            <div class="stat-icon" style="background: #f0ebe1; color: #5c4e40;"><i class="fa-solid fa-box"></i></div>
            <div class="stat-details">
                <h3>Total Colmenas</h3>
                <p>@Model.TotalColmenas</p>
            </div>
        </div>
        <div class="stat-card" style="border-left-color: #e5989b;">
            <div class="stat-icon" style="background: #fdf0f0; color: #e5989b;"><i class="fa-solid fa-jar"></i></div>
            <div class="stat-details">
                <h3>Kilos Producidos</h3>
                <p>@Model.TotalKilosMiel <span style="font-size: 1rem; color: #7a6e62;">kg</span></p>
            </div>
        </div>
    </div>
    
    <!-- Middle Row: Chart & Tasks -->
    <div class="middle-row">
        <div class="chart-container">
            <h2 class="section-title"><i class="fa-solid fa-chart-line" style="color: #d4a373;"></i> Producción de Miel</h2>
            <canvas id="produccionChart" height="100"></canvas>
        </div>
        
        <div class="tasks-container">
            <h2 class="section-title"><i class="fa-solid fa-clipboard-list" style="color: #5c4e40;"></i> Próximas Tareas</h2>
            
            @if (Model.TareasPendientes.Any())
            {
                foreach(var tarea in Model.TareasPendientes)
                {
                    <div class="task-item">
                        <div class="task-date">
                            <span class="day">@tarea.FechaVencimiento.ToString("dd")</span>
                            <span class="month">@tarea.FechaVencimiento.ToString("MMM")</span>
                        </div>
                        <div class="task-info">
                            <h4>@tarea.Titulo</h4>
                            <p><i class="fa-solid fa-location-dot"></i> @tarea.NombreApiario</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <p style="color: #7a6e62; font-style: italic; text-align: center; margin-top: 40px;">No hay tareas pendientes.</p>
            }
        </div>
    </div>
    
    <!-- Bottom Row: Map -->
    <div class="map-container">
        <h2 class="section-title"><i class="fa-solid fa-map" style="color: #7a6e62;"></i> Ubicación de Apiarios</h2>
        <div id="map"></div>
    </div>
    
</div>

<!-- Data injection for JS -->
<div id="chartData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GraficoProduccion))</div>
<div id="mapData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MapaApiarios))</div>

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Leaflet.js -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            
            // --- 1. CONFIGURACIÓN DEL GRÁFICO (Chart.js) ---
            const chartDataRaw = document.getElementById("chartData").innerText;
            const produccionData = JSON.parse(chartDataRaw);
            
            const labels = produccionData.map(d => d.Mes);
            const data = produccionData.map(d => d.TotalKg);
            
            const ctx = document.getElementById('produccionChart').getContext('2d');
            
            // Gradient fill
            let gradient = ctx.createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, 'rgba(212, 163, 115, 0.5)'); // #d4a373 con opacidad
            gradient.addColorStop(1, 'rgba(212, 163, 115, 0.0)');
            
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Kilos Cosechados',
                        data: data,
                        borderColor: '#d4a373',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#d4a373',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true,
                        tension: 0.4 // Curvas suaves
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#f0ebe1' }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
            
            
            // --- 2. CONFIGURACIÓN DEL MAPA (Leaflet.js) ---
            const mapDataRaw = document.getElementById("mapData").innerText;
            const apiarios = JSON.parse(mapDataRaw);
            
            // Coordenadas por defecto (Uruguay aprox) si no hay apiarios
            let defaultLat = -32.5228;
            let defaultLng = -55.7658;
            let zoom = 6;
            
            if (apiarios.length > 0) {
                defaultLat = apiarios[0].Latitud;
                defaultLng = apiarios[0].Longitud;
                zoom = 10;
            }
            
            const map = L.map('map').setView([defaultLat, defaultLng], zoom);
            
            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap contributors &copy; CARTO'
            }).addTo(map);
            
            // Custom Icon
            const beeIcon = L.divIcon({
                html: '<i class="fa-solid fa-location-dot" style="color: #d4a373; font-size: 2rem; text-shadow: 2px 2px 4px rgba(0,0,0,0.3);"></i>',
                className: 'custom-div-icon',
                iconSize: [30, 42],
                iconAnchor: [15, 42],
                popupAnchor: [0, -40]
            });
            
            // Add pins
            apiarios.forEach(a => {
                L.marker([a.Latitud, a.Longitud], {icon: beeIcon})
                 .addTo(map)
                 .bindPopup(`<b>${a.Nombre}</b><br>${a.Zona}`);
            });
            
            // Auto fit bounds if multiple markers
            if (apiarios.length > 1) {
                const bounds = L.latLngBounds(apiarios.map(a => [a.Latitud, a.Longitud]));
                map.fitBounds(bounds, { padding: [50, 50] });
            }
        });
    </script>
}
