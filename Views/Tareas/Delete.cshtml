@model ObligatorioApiario.Models.TareaViewModel

@{
    ViewData["Title"] = "Eliminar Tarea";
}

<div style="max-width: 600px; margin: 0 auto; padding-top: 2rem;">
    <div class="calendar-header" style="flex-direction: column; text-align: center; margin-bottom: 1.5rem;">
        <h1 class="page-title text-center" style="color: #d9534f; width: 100%; margin-bottom: 0.5rem;">Eliminar Tarea</h1>
        <p class="page-description text-center mb-4" style="width: 100%; max-width: 100%; color: #666;">¿Estás seguro de que deseas eliminar esta tarea?</p>
    </div>

    <div class="card p-4 text-center" style="border-top: 4px solid #d9534f; background-color: #fff; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); padding: 2rem;">
        <i class="fa-solid fa-triangle-exclamation" style="font-size: 3rem; color: #d9534f; margin-bottom: 1rem;"></i>
        <h2 style="color: #333; margin-top: 10px; margin-bottom: 15px; font-weight: 700;">@Model.Titulo</h2>
        
        <p class="text-muted mt-2" style="font-size: 0.95rem; color: #555; margin-bottom: 5px;"><strong>Prioridad:</strong> @Model.NivelPrioridad</p>
        <p class="text-muted" style="font-size: 0.95rem; color: #555; margin-bottom: 5px;"><strong>Apiario:</strong> @Model.NombreApiario</p>
        <p class="text-muted" style="font-size: 0.95rem; color: #555; margin-bottom: 20px;"><strong>Fecha:</strong> @Model.FechaVencimiento.ToString("dd MMM, yyyy", new System.Globalization.CultureInfo("es-ES"))</p>

        <div class="alert alert-warning mt-4 text-left" style="background-color: #fff3cd; color: #856404; border: 1px solid #ffeeba; border-radius: 8px; padding: 15px; margin-top: 20px; text-align: left; font-size: 0.9rem;">
            <strong>¡Atención!</strong> Esta acción es irreversible. Se eliminarán permanentemente todos los datos asociados a esta tarea.
        </div>

        <form asp-action="Delete" method="post" style="display: flex; justify-content: center; gap: 15px; margin-top: 25px;">
            <input type="hidden" name="Id" value="@Model.Id" />
            <a asp-action="Index" class="btn-outline" style="border-radius: 8px; text-decoration: none; display: flex; align-items: center; justify-content: center; padding: 10px 25px; color: #555; border: 1px solid #ccc; font-weight: 600; cursor: pointer;">Cancelar</a>
            <button type="submit" class="btn-primary" style="background-color: #d9534f; border-color: #d9534f; border-radius: 8px; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 25px; color: white; border: none; font-weight: 600; cursor: pointer;">
                <i class="fa-regular fa-trash-can"></i> Confirmar Eliminación
            </button>
        </form>
    </div>
</div>
