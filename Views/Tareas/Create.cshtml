@model ObligatorioApiario.Models.CreateTareasViewModel
@{
    ViewData["Title"] = "Nueva Tarea";
}

<div class="breadcrumb-tareas">
    <a href="#">Apiarios</a> <i class="fa-solid fa-chevron-right" style="font-size:0.6rem;"></i> 
    <a href="#">Tareas</a> <i class="fa-solid fa-chevron-right" style="font-size:0.6rem;"></i> 
    <span class="active">Nueva Tarea</span>
</div>

<h2 class="page-title" style="margin-bottom: 2rem;">Nueva Tarea</h2>

<div class="cards-layout">
    <!-- Columna Izquierda: Formulario -->
    <div class="form-white-card">
        <form asp-action="Create" method="post" id="create-tareas-form">
            
            <h3 style="margin-bottom: 1.5rem; color: #5c4e40; font-size: 1.1rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Datos Generales</h3>

            <div class="form-row">
                <div class="col-half form-group">
                    <label class="form-label"><i class="fa-solid fa-location-dot"></i> Apiario <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                    <select name="NombreApiario" id="NombreApiario" class="form-input form-select" required>
                        <option value="">Selecciona un apiario</option>
                        @if (ViewBag.Apiarios != null)
                        {
                            foreach (var apiario in (List<ObligatorioApiario.Models.Apiario>)ViewBag.Apiarios)
                            {
                                <option value="@apiario.Nombre">@apiario.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-half form-group">
                    <label class="form-label"><i class="fa-regular fa-calendar-days"></i> Fecha Programada <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                    <input type="date" name="FechaVencimiento" class="form-input" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label"><i class="fa-solid fa-circle-info"></i> Estado <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                <select name="Estado" class="form-input form-select" required>
                    <option value="Programada" selected>Programada</option>
                    <option value="En Progreso">En Progreso</option>
                    <option value="Completada">Completada</option>
                    <option value="Cancelada">Cancelada</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label"><i class="fa-solid fa-screwdriver-wrench"></i> Herramientas Requeridas (separadas por comas)</label>
                <input type="text" name="HerramientasRequeridas" class="form-input" placeholder="Ej: Ahumador, Kit Varroa, Espátula" />
            </div>

            <div class="form-row">
                <div class="col-half form-group">
                    <label class="form-label"><i class="fa-solid fa-cloud-sun"></i> Clima</label>
                    <select name="ClimaEstado" class="form-input form-select">
                        <option value="Soleado" selected>Soleado</option>
                        <option value="Nublado">Nublado</option>
                        <option value="Lluvioso">Lluvioso</option>
                        <option value="Templado">Templado</option>
                        <option value="Viento Fuerte">Viento Fuerte</option>
                    </select>
                </div>
                <div class="col-half form-group">
                    <label class="form-label"><i class="fa-solid fa-temperature-half"></i> Temperatura</label>
                    <input type="text" name="ClimaTemperatura" class="form-input" placeholder="Ej: 22ºC" value="22ºC" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label"><i class="fa-solid fa-triangle-exclamation"></i> Colmenas en Riesgo</label>
                <input type="text" name="ColmenasRiesgo" class="form-input" placeholder="Ej: 2/16" value="0/0" />
            </div>

            <h3 style="margin-top: 2rem; margin-bottom: 1.5rem; color: #5c4e40; font-size: 1.1rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Tareas por Colmena</h3>
            <p style="font-size: 0.85rem; color: #7a6e62; margin-bottom: 1.5rem;">
                Selecciona un apiario arriba para ver sus colmenas. Las colmenas que dejes con el título en blanco no crearán una tarea.
            </p>

            <div id="colmenas-container">
                <div style="text-align: center; padding: 2rem; color: #999;">
                    <i class="fa-solid fa-arrow-up" style="font-size: 2rem; margin-bottom: 1rem; color: #ddd;"></i>
                    <p>Por favor, selecciona un apiario para asignar tareas.</p>
                </div>
            </div>

            <div class="form-row" style="margin-top: 3rem;">
                <button type="button" onclick="submitForm()" class="btn-primary col-half" style="border-radius: 8px;">Crear Tareas</button>
                <a asp-action="Index" class="btn-outline col-half" style="border-radius: 8px; color: #555; border-color: #555; text-decoration: none; display: flex; justify-content: center; align-items: center;">Cancelar</a>
            </div>
        </form>
    </div>

    <!-- Columna Derecha: Widgets -->
    <div class="widgets-sidebar">
        <!-- Guía de Tareas -->
        <div class="widget-card">
            <h3><i class="fa-regular fa-circle-info"></i> Guía de Tareas</h3>
            <p>Las tareas ayudan a mantener un registro preciso de las intervenciones en cada colmena. Priorizar adecuadamente garantiza la salud del apiario.</p>
            <ul class="widget-list">
                <li><i class="fa-regular fa-circle-check"></i> <span>Inspecciones de Varroa cada <strong>15 días.</strong></span></li>
                <li><i class="fa-regular fa-circle-check"></i> <span>Control de reservas en <strong>invierno.</strong></span></li>
                <li><i class="fa-regular fa-circle-check"></i> <span>Mantenimiento de alzas <strong>pre-cosecha.</strong></span></li>
            </ul>
        </div>

        <!-- Condición Local -->
        <div class="weather-card">
            <div class="weather-header">Condición Local</div>
            <div class="weather-temp">
                <i class="fa-regular fa-sun"></i> 24°C
            </div>
            <p class="weather-desc">Perfecto para inspecciones de campo hoy.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var selectApiario = document.getElementById('NombreApiario');
            var colmenasContainer = document.getElementById('colmenas-container');

            selectApiario.addEventListener('change', function() {
                var nombreApiario = this.value;
                if (!nombreApiario) {
                    colmenasContainer.innerHTML = '<div style="text-align: center; padding: 2rem; color: #999;"><i class="fa-solid fa-arrow-up" style="font-size: 2rem; margin-bottom: 1rem; color: #ddd;"></i><p>Por favor, selecciona un apiario para asignar tareas.</p></div>';
                    return;
                }

                colmenasContainer.innerHTML = '<div style="text-align: center; padding: 2rem; color: #999;"><i class="fa-solid fa-spinner fa-spin" style="font-size: 2rem;"></i><p>Cargando colmenas...</p></div>';

                fetch('/Tareas/GetColmenasPorApiario?nombreApiario=' + encodeURIComponent(nombreApiario))
                    .then(response => response.json())
                    .then(data => {
                        if (data.length === 0) {
                            colmenasContainer.innerHTML = '<div style="text-align: center; padding: 2rem; color: #d9534f;"><i class="fa-solid fa-triangle-exclamation" style="font-size: 2rem; margin-bottom: 1rem;"></i><p>Este apiario no tiene colmenas registradas.</p></div>';
                            return;
                        }

                        var html = '';
                        data.forEach((colmena, index) => {
                            html += `
                            <div class="colmena-task-card" style="background: #fdfdfd; border: 1px solid #e8e3dc; border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                                    <h4 style="margin: 0; color: #d48e45;"><i class="fa-solid fa-box" style="margin-right: 5px;"></i> Colmena: ${colmena.identificador}</h4>
                                </div>
                                
                                <input type="hidden" name="TareasColmenas[${index}].ColmenaId" value="${colmena.id}" />
                                <input type="hidden" name="TareasColmenas[${index}].IdentificadorColmena" value="${colmena.identificador}" />
                                
                                <div class="form-group">
                                    <label class="form-label" style="font-size: 0.85rem;">Título de la Tarea <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                                    <input type="text" name="TareasColmenas[${index}].Titulo" class="form-input" placeholder="Ej: Inspección Sanitaria..." />
                                </div>

                                <div class="form-group">
                                    <label class="form-label" style="font-size: 0.85rem;">Descripción y Detalles (Opcional)</label>
                                    <textarea name="TareasColmenas[${index}].Descripcion" class="form-input form-textarea" placeholder="Pasos específicos..."></textarea>
                                </div>

                                <div class="form-row" style="margin-bottom: 0;">
                                    <div class="col-half form-group" style="margin-bottom: 0;">
                                        <label class="form-label" style="font-size: 0.85rem;">Notas de Campo</label>
                                        <input type="text" name="TareasColmenas[${index}].NotasCampo" class="form-input" placeholder="Opcional" />
                                    </div>
                                    <div class="col-half form-group" style="margin-bottom: 0;">
                                        <label class="form-label" style="font-size: 0.85rem;">Nivel de Prioridad</label>
                                        <div class="priority-selector" style="margin-bottom: 0; padding: 0;">
                                            <label class="priority-pill" style="padding: 4px 8px; font-size: 0.8rem;">
                                                <input type="radio" name="TareasColmenas[${index}].NivelPrioridad" value="Baja" />
                                                <div class="priority-dot baja"></div> Baja
                                            </label>
                                            <label class="priority-pill" style="padding: 4px 8px; font-size: 0.8rem;">
                                                <input type="radio" name="TareasColmenas[${index}].NivelPrioridad" value="Media" checked />
                                                <div class="priority-dot media"></div> Media
                                            </label>
                                            <label class="priority-pill" style="padding: 4px 8px; font-size: 0.8rem;">
                                                <input type="radio" name="TareasColmenas[${index}].NivelPrioridad" value="Alta" />
                                                <div class="priority-dot alta"></div> Alta
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>`;
                        });
                        colmenasContainer.innerHTML = html;
                    })
                    .catch(error => {
                        console.error('Error fetching colmenas:', error);
                        colmenasContainer.innerHTML = '<div style="text-align: center; padding: 2rem; color: #d9534f;"><p>Error al cargar colmenas.</p></div>';
                    });
            });
        });

        function submitForm() {
            var form = document.getElementById('create-tareas-form');
            if (form.checkValidity()) {
                var inputs = document.querySelectorAll('input[name^="TareasColmenas"][name$=".Titulo"]');
                var hasTasks = Array.from(inputs).some(input => input.value.trim() !== '');
                
                if (!hasTasks) {
                    alert('Debes ingresar un título para al menos una colmena.');
                    return;
                }
                form.submit();
            } else {
                form.reportValidity();
            }
        }
    </script>
}
