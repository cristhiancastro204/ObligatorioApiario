@model ObligatorioApiario.Models.Colmena

@{
    ViewData["Title"] = "Crear Colmena";
}

<div style="max-width: 1000px; margin: 0 auto; padding-bottom: 2rem;">
    <div class="breadcrumb mb-2" style="font-size: 0.8rem; font-weight: 600; color: #7a6e62; letter-spacing: 0.5px;">
        <span class="breadcrumb-item text-muted">Apiarios</span>
        <i class="fa-solid fa-chevron-right mx-2" style="font-size: 0.6rem;"></i>
        <span class="breadcrumb-item text-muted">@ViewBag.ApiarioNombre</span>
        <i class="fa-solid fa-chevron-right mx-2" style="font-size: 0.6rem;"></i>
        <span style="color: #8c4b14; text-transform: uppercase;">Nueva Colmena</span>
    </div>

    <div class="details-header d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title" style="margin: 0; font-size: 2.2rem; font-weight: 800; color: #8c4b14;">Crear Colmena</h1>
    </div>

    <p class="page-description mb-4">Registra una nueva colmena dentro del apiario <strong>@ViewBag.ApiarioNombre</strong>. Completa todos los datos de salud e identificación para un seguimiento correcto.</p>

    <form asp-action="Create" method="post" class="apiario-form">
        <input type="hidden" asp-for="ApiarioId" />

        <div class="cards-layout">
            
            <!-- Tarjeta 1: Información General -->
            <div class="card general-info-card" style="border-radius: 12px; margin-bottom: 24px;">
                <div class="card-header" style="padding: 16px 20px; border-bottom: 1px solid #e8e3dc; background: white; border-radius: 12px 12px 0 0; font-weight: 700; color: #2d261e;">
                    <i class="fa-solid fa-layer-group" style="color: #8c4b14; margin-right: 8px;"></i> Información General
                </div>
                <div class="card-body p-4">
                    
                    <div class="form-row" style="display: flex; gap: 20px; margin-bottom: 16px;">
                        <div class="form-group" style="flex: 1;">
                            <label asp-for="CantidadAbejas" class="form-label" style="font-size: 0.8rem; font-weight: 700; color: #7a6e62; letter-spacing: 0.5px;">CANTIDAD DE ABEJAS <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                            <input asp-for="CantidadAbejas" class="form-input" style="width: 100%; padding: 10px 14px; border: 1.5px solid #e8e3dc; border-radius: 8px; font-size: 0.95rem; background-color: #fdfbf7;" type="number" min="0" />
                        </div>

                        <div class="form-group" style="flex: 1;">
                            <label asp-for="TipoAbeja" class="form-label" style="font-size: 0.8rem; font-weight: 700; color: #7a6e62; letter-spacing: 0.5px;">TIPO DE ABEJA <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                            <input asp-for="TipoAbeja" class="form-input" style="width: 100%; padding: 10px 14px; border: 1.5px solid #e8e3dc; border-radius: 8px; font-size: 0.95rem; background-color: #fdfbf7;" placeholder="Ej: Italiana, Carniola..." />
                        </div>
                    </div>

                    <div class="form-group" style="margin-bottom: 16px;">
                        <label asp-for="Notas" class="form-label" style="font-size: 0.8rem; font-weight: 700; color: #7a6e62; letter-spacing: 0.5px;">NOTAS</label>
                        <textarea asp-for="Notas" class="form-input form-textarea" style="width: 100%; padding: 10px 14px; border: 1.5px solid #e8e3dc; border-radius: 8px; font-size: 0.95rem; background-color: #fdfbf7; min-height: 100px;" placeholder="Comportamiento, origen de la colonia, etc..."></textarea>
                    </div>

                </div>
            </div>

            <!-- Tarjeta 2: Datos Técnicos y Salud -->
            <div class="card technical-data-card" style="border-radius: 12px;">
                <div class="card-header" style="padding: 16px 20px; border-bottom: 1px solid #e8e3dc; background: white; border-radius: 12px 12px 0 0; font-weight: 700; color: #2d261e;">
                    <i class="fa-solid fa-heart-pulse" style="color: #8c4b14; margin-right: 8px;"></i> Estado y Salud
                </div>
                <div class="card-body p-4">

                    <div class="form-row" style="display: flex; gap: 20px; margin-bottom: 16px;">
                        <div class="form-group" style="flex: 1;">
                            <label asp-for="EstadoSalud" class="form-label" style="font-size: 0.8rem; font-weight: 700; color: #7a6e62; letter-spacing: 0.5px;">ESTADO DE SALUD <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                            <select asp-for="EstadoSalud" class="form-input form-select" style="width: 100%; padding: 10px 14px; border: 1.5px solid #e8e3dc; border-radius: 8px; font-size: 0.95rem; background-color: #fdfbf7; color: #2d261e; font-weight: 600;">
                                <option value="Saludable">Saludable</option>
                                <option value="Fuerte">Fuerte</option>
                                <option value="En Observación">En Observación</option>
                                <option value="Débil">Débil</option>
                                <option value="Enferma">Enferma</option>
                            </select>
                        </div>

                        <div class="form-group" style="flex: 1;">
                            <label asp-for="CantidadMarcos" class="form-label" style="font-size: 0.8rem; font-weight: 700; color: #7a6e62; letter-spacing: 0.5px;">CANTIDAD DE MARCOS <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                            <input asp-for="CantidadMarcos" class="form-input" style="width: 100%; padding: 10px 14px; border: 1.5px solid #e8e3dc; border-radius: 8px; font-size: 0.95rem; background-color: #fdfbf7;" type="number" min="1" max="20" />
                        </div>
                    </div>

                    <div class="form-row" style="display: flex; gap: 20px; margin-bottom: 0;">
                        <div class="form-group" style="flex: 1;">
                            <label asp-for="AnioReina" class="form-label" style="font-size: 0.8rem; font-weight: 700; color: #7a6e62; letter-spacing: 0.5px;">AÑO DE LA REINA <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                            <input asp-for="AnioReina" class="form-input" style="width: 100%; padding: 10px 14px; border: 1.5px solid #e8e3dc; border-radius: 8px; font-size: 0.95rem; background-color: #fdfbf7;" type="number" min="2020" max="2030" />
                        </div>

                        <div class="form-group" style="flex: 1;">
                            <label asp-for="FechaInstalacion" class="form-label" style="font-size: 0.8rem; font-weight: 700; color: #7a6e62; letter-spacing: 0.5px;">FECHA DE INSTALACIÓN <i class="fa-solid fa-circle-exclamation required-icon" title="Campo obligatorio"></i></label>
                            <input asp-for="FechaInstalacion" class="form-input" style="width: 100%; padding: 10px 14px; border: 1.5px solid #e8e3dc; border-radius: 8px; font-size: 0.95rem; background-color: #fdfbf7;" type="date" />
                        </div>
                    </div>

                </div>
            </div>

        </div>

        <div class="form-actions mt-4" style="display: flex; gap: 16px;">
            <a asp-action="Details" asp-controller="Apiarios" asp-route-id="@Model.ApiarioId" class="btn-outline" style="border: 1.5px solid #e8e3dc; background: transparent; color: #7a6e62; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none;">Cancelar</a>
            <button type="submit" class="btn-primary" style="background-color: #8c4b14; color: white; border: none; padding: 12px 24px; border-radius: 8px; font-weight: 700; cursor: pointer;">
                <i class="fa-regular fa-circle-check" style="margin-right: 8px;"></i> Guardar Colmena
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
