@model ObligatorioApiario.Models.Colmena

@{
    ViewData["Title"] = "Detalles de " + Model.Identificador;
}

<div class="details-page-container" style="max-width: 1200px; margin: 0 auto; padding-bottom: 2rem;">
    
    <div class="breadcrumb mb-2" style="font-size: 0.8rem; font-weight: 600; color: #7a6e62; letter-spacing: 0.5px;">
        <span>Apiarios</span> <i class="fa-solid fa-chevron-right mx-2" style="font-size: 0.6rem;"></i> 
        <a asp-action="Details" asp-controller="Apiarios" asp-route-id="@Model.ApiarioId" style="color: #7a6e62; text-decoration: none;">@Model.Apiario?.Nombre</a> <i class="fa-solid fa-chevron-right mx-2" style="font-size: 0.6rem;"></i> 
        <span style="color: #8c4b14; text-transform: uppercase;">@Model.Identificador</span>
    </div>

    <div class="details-header d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title" style="margin: 0; font-size: 2.2rem; font-weight: 800; color: #8c4b14;">@Model.Identificador</h1>
        <div class="header-actions d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-outline" style="border-radius: 8px; padding: 6px 16px; font-size: 0.9rem; text-decoration: none; color: #7a6e62; border: 1.5px solid #e8e3dc;">
                <i class="fa-solid fa-pen" style="margin-right: 5px;"></i> Editar
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-outline" style="border-radius: 8px; padding: 6px 16px; font-size: 0.9rem; text-decoration: none; color: #d9534f; border: 1.5px solid #fcedec; background-color: #fcedec;">
                <i class="fa-solid fa-trash" style="margin-right: 5px;"></i> Eliminar
            </a>
        </div>
    </div>

    <div class="details-grid" style="display: grid; grid-template-columns: 1fr 2fr; gap: 24px;">
        
        <!-- COLUMNA IZQUIERDA: DATOS PRINCIPALES -->
        <div class="card map-detail-card" style="display: flex; flex-direction: column; border-radius: 12px; height: 100%;">
            <div class="card-header d-flex justify-content-between align-items-center" style="padding: 16px 20px; border-bottom: 1px solid #e8e3dc; background: white; border-radius: 12px 12px 0 0;">
                <div style="font-size: 1.1rem; font-weight: 700; color: #2d261e; display: flex; align-items: center;">
                    <div style="background-color: #f7e6d9; padding: 6px; border-radius: 6px; margin-right: 12px; color: #8c4b14; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-clipboard-check"></i>
                    </div>
                    Estado Principal
                </div>
            </div>
            
            <div class="card-body p-4">
                <div style="text-align: center; margin-bottom: 25px;">
                    <span class="badge" style="background-color: @(Model.EstadoSalud == "Saludable" || Model.EstadoSalud == "Fuerte" ? "#e6f6eb" : Model.EstadoSalud == "En Observación" ? "#fcf1d7" : "#fcedec"); color: @(Model.EstadoSalud == "Saludable" || Model.EstadoSalud == "Fuerte" ? "#2e8b57" : Model.EstadoSalud == "En Observación" ? "#8c4b14" : "#d9534f"); padding: 8px 16px; border-radius: 20px; font-size: 0.95rem; font-weight: 800; display: inline-block;">
                        @if(Model.EstadoSalud == "Saludable" || Model.EstadoSalud == "Fuerte") { <i class="fa-solid fa-heart-circle-check" style="margin-right: 5px;"></i> }
                        else if(Model.EstadoSalud == "En Observación") { <i class="fa-solid fa-eye" style="margin-right: 5px;"></i> }
                        else { <i class="fa-solid fa-virus" style="margin-right: 5px;"></i> }
                        @Model.EstadoSalud
                    </span>
                </div>

                <div class="data-rows" style="display: flex; flex-direction: column; gap: 12px;">
                    <div class="data-row d-flex justify-content-between align-items-center" style="background-color: #f8f6f4; padding: 10px 16px; border-radius: 8px;">
                        <span style="color: #7a6e62; font-size: 0.9rem; display: flex; align-items: center;">
                            <i class="fa-solid fa-calendar-plus" style="width: 20px; text-align: center; margin-right: 8px;"></i> Instalación
                        </span>
                        <span style="font-weight: 700; color: #2d261e; font-size: 0.9rem;">@Model.FechaInstalacion.ToString("dd MMM yyyy")</span>
                    </div>

                    <div class="data-row d-flex justify-content-between align-items-center" style="background-color: #f8f6f4; padding: 10px 16px; border-radius: 8px;">
                        <span style="color: #7a6e62; font-size: 0.9rem; display: flex; align-items: center;">
                            <i class="fa-solid fa-bug" style="width: 20px; text-align: center; margin-right: 8px;"></i> Tipo Abeja
                        </span>
                        <span style="font-weight: 700; color: #2d261e; font-size: 0.9rem;">@(string.IsNullOrEmpty(Model.TipoAbeja) ? "No especificado" : Model.TipoAbeja)</span>
                    </div>

                    <div class="data-row d-flex justify-content-between align-items-center" style="background-color: #f8f6f4; padding: 10px 16px; border-radius: 8px;">
                        <span style="color: #7a6e62; font-size: 0.9rem; display: flex; align-items: center;">
                            <i class="fa-solid fa-crown" style="width: 20px; text-align: center; margin-right: 8px;"></i> Año Reina
                        </span>
                        <span style="font-weight: 700; color: #2d261e; font-size: 0.9rem;">@Model.AnioReina</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- COLUMNA DERECHA: MÉTRICAS Y NOTAS -->
        <div class="details-right-col" style="display: flex; flex-direction: column; gap: 24px;">
            
            <!-- Tarjeta de Métricas Rápidas -->
            <div style="display: flex; gap: 20px;">
                <div class="card p-4" style="border-radius: 12px; flex: 1; text-align: center; background-color: white; border: 1px solid #e8e3dc;">
                    <div style="background-color: #fdf3e8; width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px auto;">
                        <i class="fa-solid fa-cubes-stacked" style="color: #d48e45; font-size: 1.2rem;"></i>
                    </div>
                    <span class="d-block" style="font-size: 1.8rem; font-weight: 800; color: #8c4b14;">@Model.CantidadMarcos</span>
                    <span class="d-block mt-1" style="font-size: 0.75rem; font-weight: 700; color: #7a6e62; letter-spacing: 0.5px; text-transform: uppercase;">Marcos Activos</span>
                </div>

                <div class="card p-4" style="border-radius: 12px; flex: 1; text-align: center; background-color: white; border: 1px solid #e8e3dc;">
                    <div style="background-color: #fdf3e8; width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px auto;">
                        <i class="fa-solid fa-users" style="color: #d48e45; font-size: 1.2rem;"></i>
                    </div>
                    <span class="d-block" style="font-size: 1.8rem; font-weight: 800; color: #8c4b14;">@Model.CantidadAbejas.ToString("N0")</span>
                    <span class="d-block mt-1" style="font-size: 0.75rem; font-weight: 700; color: #7a6e62; letter-spacing: 0.5px; text-transform: uppercase;">Población Estimada</span>
                </div>
            </div>

            <!-- Tarjeta Notas -->
            <div class="card p-4" style="border-radius: 12px; flex: 1; background-color: white; border: 1px solid #e8e3dc;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 style="font-size: 1.1rem; font-weight: 700; color: #2d261e; margin: 0; display: flex; align-items: center;">
                        <i class="fa-solid fa-bars-staggered" style="color: #8c4b14; margin-right: 10px;"></i> Comportamiento e Historial
                    </h3>
                </div>
                
                <div class="notes-content" style="background-color: #fdfbf7; border: 1.5px dashed #d4c4b7; border-radius: 8px; padding: 20px; height: 100%; min-height: 180px;">
                    @if (string.IsNullOrEmpty(Model.Notas))
                    {
                        <div style="text-align: center; color: #7a6e62; margin-top: 2rem;">
                            <i class="fa-regular fa-comment-dots" style="font-size: 2rem; margin-bottom: 10px; color: #e8e3dc;"></i>
                            <p style="font-size: 0.95rem;">No hay notas registradas para esta colmena aún.</p>
                            <a asp-action="Edit" asp-route-id="@Model.Id" style="color: #8c4b14; font-weight: 600; text-decoration: none; font-size: 0.85rem;">Agregar notas ahora</a>
                        </div>
                    }
                    else
                    {
                        <p style="color: #5c4e40; font-size: 0.95rem; line-height: 1.6; margin: 0;">@Model.Notas</p>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
